# PostgreSQL (docker-compose defaults)
POSTGRES_USER=homelab
POSTGRES_PASSWORD=homelab
POSTGRES_DB=homelab_dashboard
DATABASE_URL=postgresql+psycopg://homelab:homelab@localhost:5432/homelab_dashboard

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Frontend (Vite)
VITE_API_URL=http://localhost:8000

# Authentication
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
JWT_SECRET=generate-a-long-random-string
JWT_EXPIRE_HOURS=24
COOKIE_SECURE=false
